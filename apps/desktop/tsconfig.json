{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@todo/core": ["../../packages/core/src/index.ts"],
      "@todo/store": ["../../packages/store/src/index.ts"]
    }
  },
  "include": ["src", "../web/src"],
  "exclude": ["electron", "dist", "dist-electron", "release"]
}
